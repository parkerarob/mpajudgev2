{
  "name": "mpa-judge-v2",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "test:unit": "vitest run tests/unit/*.test.js",
    "test:security": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 GCLOUD_PROJECT=mpa-judge-v2 npx firebase emulators:exec --project mpa-judge-v2 --only firestore,storage \"vitest run tests/security/*.test.mjs\"",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:smoke": "MPA_PLAYWRIGHT_REPORT=reports/e2e_smoke_results.json playwright test -c playwright.config.ts tests/e2e/smoke.spec.ts",
    "test:e2e:release": "MPA_PLAYWRIGHT_REPORT=reports/e2e_release_results.json playwright test -c playwright.config.ts tests/e2e/release.spec.ts",
    "report:e2e:smoke": "MPA_E2E_REPORT_PATH=reports/e2e_smoke_results.json MPA_E2E_REPORT_MD_PATH=reports/e2e_smoke_report.md MPA_E2E_REPORT_TITLE='Smoke E2E Report' node scripts/e2e_report.js",
    "report:e2e:release": "MPA_E2E_REPORT_PATH=reports/e2e_release_results.json MPA_E2E_REPORT_MD_PATH=reports/e2e_release_report.md MPA_E2E_REPORT_TITLE='Release E2E Report' node scripts/e2e_report.js",
    "verify:baseline": "node scripts/verify_baseline.js"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.49.0",
    "firebase": "^10.12.5",
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^14.19.1",
    "vitest": "^4.0.18"
  }
}
